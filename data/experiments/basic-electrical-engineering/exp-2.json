        "calculation": {
            "id": "calculation",
            "title": "Calculations",
            "isApplicable": true,
            "content": [
                {
                    "type": "text",
                    "content": "The theoretical values are calculated using the standard circuit analysis formulae for Series-Parallel circuits."
                },
                {
                    "type": "text",
                    "content": "**Step 1: Calculate I₁ (Due to V₁ alone)**\nWhen V₂ is shorted, R₂ and R₃ are in parallel."
                },
                {
                    "type": "equation",
                    "content": "R_eq1 = (R₂ × R₃) / (R₂ + R₃)\n      = (220 × 1000) / (220 + 1000)\n      ≈ 180.33 Ω"
                },
                {
                    "type": "equation",
                    "content": "R_T1 = R₁ + R_eq1\n     = 330 + 180.33\n     = 510.33 Ω"
                },
                {
                    "type": "equation",
                    "content": "I_source1 = V₁ / R_T1"
                },
                {
                    "type": "equation",
                    "content": "I₁ = I_source1 × (R₂ / (R₂ + R₃))    [Current Divider Rule]"
                },
                {
                    "type": "text",
                    "content": "**Step 2: Calculate I₂ (Due to V₂ alone)**\nWhen V₁ is shorted, R₁ and R₃ are in parallel."
                },
                {
                    "type": "equation",
                    "content": "R_eq2 = (R₁ × R₃) / (R₁ + R₃)\n      = (330 × 1000) / (330 + 1000)\n      ≈ 248.12 Ω"
                },
                {
                    "type": "equation",
                    "content": "R_T2 = R₂ + R_eq2\n     = 220 + 248.12\n     = 468.12 Ω"
                },
                {
                    "type": "equation",
                    "content": "I_source2 = V₂ / R_T2"
                },
                {
                    "type": "equation",
                    "content": "I₂ = I_source2 × (R₁ / (R₁ + R₃))    [Current Divider Rule]"
                },
                {
                    "type": "text",
                    "content": "**Step 3: Verification**\nThe total current when both sources are active:"
                },
                {
                    "type": "equation",
                    "content": "I_total(calc) = I₁ + I₂"
                },
                {
                    "type": "text",
                    "content": "**Step 4: Error Calculation**"
                },
                {
                    "type": "equation",
                    "content": "% Error = |(I_total(measured) - I_total(calc)) / I_total(calc)| × 100"
                }
            ]
        },
